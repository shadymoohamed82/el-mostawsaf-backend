# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myhealth_db
DB_USER=backend_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_SSL=false

# Encryption Key (نفس الـ key اللي هتستخدمه في PostgreSQL)
DB_ENCRYPTION_KEY=my_super_secret_key_32_chars_min!

# Auth (للاستخدام لاحقاً)
JWT_SECRET=my_jwt_secret_key_change_in_production

# Dev Placeholders (اتحذفوا في production)
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ROLE=doctor